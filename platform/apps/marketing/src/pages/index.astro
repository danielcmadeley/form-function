---
import Layout from "@/layouts/main.astro"
import AsciiSection from "@/components/marketing/ascii-section.astro"
import BentoGridSection from "@/components/marketing/bento-grid-section.astro"
import FooterGlowSection from "@/components/marketing/footer-glow-section.astro"
import HeatmapStrip from "@/components/marketing/heatmap-strip.astro"
import HeroSection from "@/components/marketing/hero-section.astro"
import MarketingHeader from "@/components/marketing/marketing-header.astro"
import MissionSection from "@/components/marketing/mission-section.astro"
import NewsletterSection from "@/components/marketing/newsletter-section.astro"
import ProblemSolvedSection from "@/components/marketing/problem-solved-section.astro"
import ServicesSection from "@/components/marketing/services-section.astro"
---

<Layout>
  <main class="relative overflow-hidden bg-neutral-50" id="platform">
    <MarketingHeader />
    <HeroSection />
    <AsciiSection />
    <ProblemSolvedSection />
    <MissionSection />
    <ServicesSection />
    <HeatmapStrip />
    <NewsletterSection />
    <BentoGridSection />
    <FooterGlowSection />
  </main>
</Layout>
