---
import MarketingHeader from "@/components/marketing/header/marketing-header.astro"
import Layout from "@/layouts/main.astro"
---

<Layout>
  <main class="relative min-h-screen bg-neutral-50" id="pricing">
    <MarketingHeader />
    <section class="mx-auto w-full max-w-[calc(100%-100px)] border-x border-fuchsia-200/70 pt-28 pb-16 xl:max-w-5xl">
      <div class="px-6 md:px-10">
        <p class="text-xs font-extrabold tracking-wide text-fuchsia-900">Pricing</p>
        <h1 class="mt-3 text-4xl font-bold leading-tight text-fuchsia-800 md:text-5xl">Flexible plans for teams of every size.</h1>
        <p class="mt-5 max-w-3xl text-lg text-neutral-700">
          Start with core collaboration and grow into advanced automation, AI workflows, and document intelligence as your
          practice scales.
        </p>
      </div>
    </section>
  </main>
</Layout>
