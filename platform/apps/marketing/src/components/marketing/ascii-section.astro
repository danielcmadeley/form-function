---
import SectionShell from "@/components/marketing/section-shell.astro";

const asciiTexture =
  "https://workers.paper.design/file-assets/01KKTYJSNKZP49MMVH1V42GW75/01KM4MMVVHNX6BKVN3CK2RPRE0.svg";
---

<section
  class="relative z-10 flex min-h-[80svh] w-full items-center justify-center border-b border-fuchsia-200 bg-cover bg-center md:min-h-[78svh]"
  style={`background-image: linear-gradient(to bottom, rgb(250 250 250 / 0.7), rgb(250 250 250 / 0.7)), url('${asciiTexture}')`}
>
  <SectionShell
    outerClass="min-h-[80svh] md:min-h-[78svh]"
    innerClass="flex min-h-[80svh] items-center justify-center pb-20 md:min-h-[78svh] md:pb-28"
    withRails={true}
  >
    <div class="max-w-[40rem] text-center">
      <h2 class="text-balance text-4xl font-bold leading-[1.08] text-fuchsia-800 md:text-[56px] md:leading-[1.08]">Built by Engineers for Engineers</h2>
      <p class="mt-4 text-sm font-semibold text-fuchsia-950/85 md:text-base">
        The construction industry moves slowly with technological advancements. We are building Form + Function so your design
        office can catch up.
      </p>
    </div>
  </SectionShell>
</section>
