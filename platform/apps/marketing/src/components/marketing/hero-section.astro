---
import SectionShell from "@/components/marketing/section-shell.astro";

const heroImage =
  "https://workers.paper.design/file-assets/01KKTYJSNKZP49MMVH1V42GW75/01KM4E0R439MJF3X3C981F17QM.png";
---

<section
  id="hero"
  class="relative z-20 flex min-h-[100svh] w-full items-center justify-center border-y border-fuchsia-200 bg-cover bg-center"
  style={`background-image: linear-gradient(to bottom, rgb(248 250 252 / 0.62), rgb(248 250 252 / 0.62)), url('${heroImage}')`}
>
  <SectionShell
    outerClass="min-h-[100svh]"
    innerClass="relative flex min-h-[100svh] items-start justify-center px-0 pt-40 pb-20 md:pt-52 md:pb-24 lg:pt-[24svh]"
    withRails={true}
  >
    <div class="max-w-[40rem] text-center">
      <p class="mb-3 text-xs font-extrabold tracking-wide text-fuchsia-900 md:text-sm">New: Eurocode Doc Search</p>
      <h1 class="text-balance text-4xl font-bold leading-[1.08] text-fuchsia-800 md:text-[56px] md:leading-[1.08]">
        The way engineers work is changing.<br />
        We&apos;re leading it.
      </h1>
    </div>
  </SectionShell>
</section>
