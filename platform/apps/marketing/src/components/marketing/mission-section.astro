---
import SectionShell from "@/components/marketing/section-shell.astro";
---

<SectionShell outerClass="border-y border-fuchsia-200/70" withRails={false}>
  <div class="mx-auto flex w-full max-w-5xl flex-col items-center border-x border-fuchsia-200/70 px-4 text-center sm:px-6">
    <p class="max-w-3xl text-balance text-3xl leading-tight text-fuchsia-100/90 md:text-5xl">
      Our mission is to make the next generation of construction consultancies more productive than ever before.
    </p>
    <a
      href="#services"
      class=" rounded-md border border-fuchsia-700 bg-fuchsia-600 px-4 py-2 text-sm font-semibold text-white shadow-[0_0_0_1px_rgba(217,70,239,0.2)]"
    >
      Learn More
    </a>
  </div>
</SectionShell>
