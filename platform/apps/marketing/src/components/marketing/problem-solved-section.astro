---
import SectionShell from "@/components/marketing/section-shell.astro";

const columns = [
  {
    title: "Automate Repetition",
    body: "Reduce repetitive calculations and free your team for higher-impact engineering work.",
  },
  {
    title: "Connect Workflows",
    body: "Link analysis, documentation, and approvals in one living workspace.",
  },
  {
    title: "Deliver Faster",
    body: "Ship better outcomes with clear status, traceability, and fewer handoff delays.",
  },
];
---

<SectionShell outerClass="border-b border-fuchsia-200/70" innerClass="py-0" withRails={false}>
  <div class="mx-auto grid w-full max-w-5xl border-x border-fuchsia-200 md:grid-cols-3 ">
    {
      columns.map((item, index) => (
        <article key={item.title} class={`min-h-64 border-fuchsia-200 p-8 md:p-10 ${index < 2 ? "md:border-r" : ""}`}>
          <h3 class="text-2xl font-semibold text-fuchsia-800">{item.title}</h3>
          <p class="mt-4 max-w-sm text-sm leading-relaxed text-neutral-700">{item.body}</p>
        </article>
      ))
    }
  </div>
</SectionShell>
