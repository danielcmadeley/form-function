---
import SectionShell from "@/components/marketing/section-shell.astro";
---

<SectionShell outerClass="border-y border-fuchsia-200/70" innerClass="py-0" withRails={false}>
  <div class="mx-auto w-full max-w-5xl border-x border-fuchsia-200/70">
    <div class="flex h-[84px] items-center justify-center border-b border-fuchsia-200/70 bg-fuchsia-50/35 px-4">
      <h3 class="text-center text-4xl font-bold text-fuchsia-800">Our 3 Core Problems</h3>
    </div>
    <div class="grid h-[415px] w-full md:grid-cols-3">
      <div class="border-fuchsia-200/70 bg-fuchsia-50/35 md:border-r"></div>
      <div class="border-fuchsia-200/70 bg-fuchsia-50/35 md:border-r"></div>
      <div class="bg-fuchsia-50/35"></div>
    </div>
  </div>
</SectionShell>
