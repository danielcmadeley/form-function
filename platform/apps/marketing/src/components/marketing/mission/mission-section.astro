---
import SectionShell from "@/components/marketing/section-shell.astro";
---

<SectionShell outerClass="border-b border-fuchsia-200" withRails={false}>
  <div class="mx-auto flex w-full flex-col items-center border-x border-fuchsia-200 px-4 py-12 text-center sm:px-6 xl:max-w-5xl">
    <p class="max-w-3xl text-balance text-3xl leading-tight text-fuchsia-100/90 md:text-5xl">
      Our mission is to make the next generation of construction consultancies more productive than ever before.
    </p>
    <a
      href="#services"
      class="mt-6 rounded-md border border-fuchsia-700 bg-fuchsia-600 px-4 py-2 text-sm font-semibold text-white"
    >
      Learn More
    </a>
  </div>
</SectionShell>
