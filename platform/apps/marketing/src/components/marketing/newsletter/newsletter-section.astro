---
import SectionShell from "@/components/marketing/section-shell.astro";
import { NewsletterForm } from "@/components/marketing/newsletter/newsletter-form";
---

<SectionShell outerClass="border-b border-fuchsia-200" withRails={false}>
  <section class="mx-auto flex min-h-[200px] w-full flex-col gap-5 border-x border-fuchsia-200 px-5 py-7 md:flex-row md:items-center md:justify-between md:gap-14 md:px-5 md:py-11 xl:max-w-5xl">
    <h3 class="max-w-md text-balance text-3xl leading-tight text-fuchsia-100/90 md:text-[40px] md:leading-[1.2] lg:text-5xl">
      Interested in the future of construction tooling?
    </h3>

    <div class="w-full max-w-[430px] md:max-w-[472px]">
      <p class="mb-3 text-left text-lg text-fuchsia-100/80 md:text-right">Subscribe to the monthly Newsletter</p>
      <NewsletterForm />
    </div>
  </section>
</SectionShell>
