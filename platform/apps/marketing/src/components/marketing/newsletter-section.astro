---
import SectionShell from "@/components/marketing/section-shell.astro";
---

<SectionShell outerClass="border-b border-fuchsia-200"  withRails={false}>
  <section class="mx-auto flex w-full max-w-5xl flex-col gap-8 border-x border-fuchsia-200/70 px-4 sm:px-6 md:flex-row md:items-center md:justify-between">
    <h3 class="max-w-md text-balance text-3xl leading-tight text-fuchsia-100/90 md:text-5xl">
      Interested in the future of construction tooling?
    </h3>

    <div class="w-full max-w-xl">
      <p class="mb-4 text-right text-lg text-fuchsia-100/80">Subscribe to the monthly Newsletter</p>
      <form class="flex items-center gap-2 rounded-lg border border-fuchsia-600 bg-fuchsia-600 p-2">
        <input
          type="email"
          placeholder="Your email address..."
          class="h-10 w-full rounded-md border border-transparent bg-transparent px-3 text-sm text-fuchsia-100 placeholder:text-fuchsia-200/70 focus:border-fuchsia-300 focus:outline-none"
        />
        <button type="submit" class="h-10 rounded-md border border-fuchsia-200/70 bg-neutral-50 px-5 text-sm font-semibold text-fuchsia-700">
          Subscribe
        </button>
      </form>
    </div>
  </section>
</SectionShell>
